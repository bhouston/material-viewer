<?xml version="1.0"?>
<materialx version="1.39" colorspace="lin_rec709">
  <nodegraph name="NG_ramp_gradient_test">
    <texcoord name="uv0" type="vector2" />
    <separate2 name="uv_split" type="multioutput">
      <input name="in" type="vector2" nodename="uv0" />
    </separate2>
    <ramp_gradient name="grad1" type="color4">
      <input name="x" type="float" nodename="uv_split" output="outx" />
      <input name="interval1" type="float" value="0.0" />
      <input name="interval2" type="float" value="0.33" />
      <input name="color1" type="color4" value="0.9, 0.1, 0.1, 1.0" />
      <input name="color2" type="color4" value="0.1, 0.9, 0.1, 1.0" />
      <input name="interpolation" type="integer" value="1" />
      <input name="prev_color" type="color4" value="0.9, 0.1, 0.1, 1.0" />
      <input name="interval_num" type="integer" value="1" />
      <input name="num_intervals" type="integer" value="3" />
    </ramp_gradient>
    <ramp_gradient name="grad2" type="color4">
      <input name="x" type="float" nodename="uv_split" output="outx" />
      <input name="interval1" type="float" value="0.33" />
      <input name="interval2" type="float" value="0.66" />
      <input name="color1" type="color4" value="0.1, 0.9, 0.1, 1.0" />
      <input name="color2" type="color4" value="0.1, 0.1, 0.9, 1.0" />
      <input name="interpolation" type="integer" value="1" />
      <input name="prev_color" type="color4" nodename="grad1" />
      <input name="interval_num" type="integer" value="2" />
      <input name="num_intervals" type="integer" value="3" />
    </ramp_gradient>
    <ramp_gradient name="grad3" type="color4">
      <input name="x" type="float" nodename="uv_split" output="outx" />
      <input name="interval1" type="float" value="0.66" />
      <input name="interval2" type="float" value="1.0" />
      <input name="color1" type="color4" value="0.1, 0.1, 0.9, 1.0" />
      <input name="color2" type="color4" value="0.9, 0.9, 0.1, 1.0" />
      <input name="interpolation" type="integer" value="1" />
      <input name="prev_color" type="color4" nodename="grad2" />
      <input name="interval_num" type="integer" value="3" />
      <input name="num_intervals" type="integer" value="3" />
    </ramp_gradient>
    <separate4 name="grad_split" type="multioutput">
      <input name="in" type="color4" nodename="grad3" />
    </separate4>
    <combine3 name="base_color" type="color3">
      <input name="in1" type="float" nodename="grad_split" output="outr" />
      <input name="in2" type="float" nodename="grad_split" output="outg" />
      <input name="in3" type="float" nodename="grad_split" output="outb" />
    </combine3>
    <output name="out_color" type="color3" nodename="base_color" />
  </nodegraph>
  <standard_surface name="SR_ramp_gradient_test" type="surfaceshader">
    <input name="base_color" type="color3" nodegraph="NG_ramp_gradient_test" output="out_color" />
    <input name="specular_roughness" type="float" value="0.5" />
  </standard_surface>
  <surfacematerial name="M_ramp_gradient_test" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="SR_ramp_gradient_test" />
  </surfacematerial>
</materialx>
